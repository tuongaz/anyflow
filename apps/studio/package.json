{
  "name": "@tuongaz/anydemo",
  "version": "0.1.0",
  "description": "Local studio that hosts file-defined demos as React Flow canvases wired to a running app via REST + SSE + Zod schema.",
  "keywords": [
    "anydemo",
    "react-flow",
    "diagram",
    "architecture",
    "playable",
    "studio",
    "hono",
    "bun"
  ],
  "homepage": "https://github.com/tuongaz/anydemo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuongaz/anydemo.git",
    "directory": "apps/studio"
  },
  "bugs": {
    "url": "https://github.com/tuongaz/anydemo/issues"
  },
  "license": "MIT",
  "author": "Tuong Le",
  "type": "module",
  "bin": {
    "anydemo": "./bin/anydemo.mjs",
    "anydemo-mcp": "./src/mcp-shim.ts"
  },
  "files": ["bin", "src", "!src/**/*.test.ts", "dist/web", "public", "README.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "bun --hot run src/cli.ts start",
    "start": "bun run src/cli.ts start",
    "test": "bun test",
    "build:web": "cd ../web && bun run build",
    "prepublishOnly": "bun run build:web && cp ../../README.md ./README.md"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dagre": "^0.8.5",
    "hono": "^4.6.14",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/dagre": "^0.7.54",
    "typescript": "^5.6.3"
  }
}
