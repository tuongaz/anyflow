{
  "version": 1,
  "name": "Checkout flow",
  "nodes": [
    {
      "id": "api-checkout",
      "type": "playNode",
      "position": { "x": 100, "y": 100 },
      "data": {
        "name": "POST /checkout",
        "kind": "service",
        "stateSource": { "kind": "request" },
        "playAction": {
          "kind": "http",
          "method": "POST",
          "url": "http://localhost:3001/checkout",
          "body": { "items": [], "customerId": "cust_1" }
        },
        "description": "Creates an order, charges the card, enqueues fulfillment."
      }
    },
    {
      "id": "worker-fulfillment",
      "type": "stateNode",
      "position": { "x": 400, "y": 100 },
      "data": {
        "name": "Fulfillment worker",
        "kind": "worker",
        "stateSource": { "kind": "event" },
        "handlerModule": "src/workers/fulfillment.ts"
      }
    }
  ],
  "connectors": [
    {
      "id": "c-checkout-fulfillment",
      "source": "api-checkout",
      "target": "worker-fulfillment",
      "kind": "event",
      "eventName": "checkout.created",
      "label": "publishes checkout.created"
    }
  ]
}
